{
  "manifest_version": 3,
  "name": "Conditional Redirect Extension",
  "version": "1.0",
  "permissions": [
    "storage",
    "tabs",
    "webNavigation",
    "contextMenus"      
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:3000/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ]
}